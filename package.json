{
  "name": "zotero-cool-paper",
  "type": "module",
  "version": "0.1.11",
  "description": "Show papers.cool KIMI paper readings and related papers in the Zotero item pane.",
  "homepage": "https://github.com/zx33/zotero-cool-paper",
  "config": {
    "addonName": "Zotero Cool Paper",
    "addonID": "zotero-cool-paper@andybear",
    "addonRef": "zoterocoolpaper",
    "addonInstance": "ZoteroCoolPaper",
    "prefsPrefix": "extensions.zotero.zoterocoolpaper"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zx33/zotero-cool-paper.git"
  },
  "keywords": [
    "zotero",
    "zotero-plugin",
    "papers.cool",
    "kimi",
    "arxiv",
    "openreview",
    "academic-research"
  ],
  "author": "AndyBear",
  "license": "MIT",
  "scripts": {
    "start": "zotero-plugin serve",
    "build": "zotero-plugin build && tsc --noEmit",
    "lint:check": "prettier --check . && eslint .",
    "lint:fix": "prettier --write . && eslint . --fix",
    "release": "zotero-plugin release",
    "test": "zotero-plugin test",
    "update-deps": "npm update --save"
  },
  "dependencies": {
    "marked": "^16.2.1",
    "zotero-plugin-toolkit": "^5.1.0-beta.13"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.10.0",
    "@zotero-plugin/eslint-config": "^0.6.7",
    "chai": "^6.2.1",
    "eslint": "^9.39.2",
    "mocha": "^11.7.5",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "zotero-plugin-scaffold": "^0.8.2",
    "zotero-types": "^4.1.0-beta.4"
  },
  "prettier": {
    "printWidth": 80,
    "tabWidth": 2,
    "endOfLine": "lf",
    "overrides": [
      {
        "files": [
          "*.xhtml"
        ],
        "options": {
          "htmlWhitespaceSensitivity": "css"
        }
      }
    ]
  }
}
